{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build_Project",
            "type": "shell",
            // 既然 build 已存在，直接进入并执行
            "command": "cmake .. && make",
            "options": {
                // 假设你的 build 文件夹就在 CMakeLists.txt 同级目录下
                "cwd": "${fileDirname}/build"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$gcc"
        }
    ]
}