{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "CMake Debug",
            "type": "cppdbg",
            "request": "launch",
            // 关键点：这个变量会询问插件“当前选中的构建目标文件路径在哪”
            "program": "${command:cmake.launchTargetPath}",
            "args": [],
            "stopAtEntry": false,
            // 这里的 cwd 建议设置为构建输出目录，方便程序读取资源文件
            "cwd": "${command:cmake.buildDirectory}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb",
            // 这里的 preLaunchTask 可以直接删掉，或者改为插件自带的构建指令
            "preLaunchTask": "CMake: build" 
        }
    ]
}